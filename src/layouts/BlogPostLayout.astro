---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import TOC from '../components/TOC.astro';
import SeriesNav from '../components/SeriesNav.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface SeriesPost {
  title: string;
  href: string;
  order: number;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  headings?: Heading[];
  seriesName?: string;
  seriesOrder?: number;
  seriesPosts?: SeriesPost[];
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], headings = [], seriesName, seriesOrder, seriesPosts = [] } = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage} type="article" pubDate={pubDate}>
  <article class="relative">
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full rounded-xl mb-8 object-cover max-h-96"
      />
    )}

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold font-heading mb-4">{title}</h1>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-muted">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span>
            (Updated: <FormattedDate date={updatedDate} />)
          </span>
        )}
      </div>

      {tags.length > 0 && (
        <div class="mt-4">
          <TagList tags={tags} />
        </div>
      )}
    </header>

    {seriesName && seriesOrder && seriesPosts.length > 0 && (
      <SeriesNav seriesName={seriesName} currentOrder={seriesOrder} posts={seriesPosts} />
    )}

    <div class="prose">
      <slot />
    </div>

    <!-- TOC: floats outside content on the right -->
    <aside class="hidden xl:block absolute top-0 left-full ml-10 w-48">
      <TOC headings={headings} />
    </aside>
  </article>
</BaseLayout>
