---
interface SeriesPost {
  title: string;
  href: string;
  order: number;
}

interface Props {
  seriesName: string;
  currentOrder: number;
  posts: SeriesPost[];
}

const { seriesName, currentOrder, posts } = Astro.props;
const sortedPosts = [...posts].sort((a, b) => a.order - b.order);
const total = sortedPosts.length;
const seriesSlug = encodeURIComponent(seriesName);
---

<details open class="rounded-lg border border-border bg-surface-alt mb-8">
  <summary class:list={[
    'flex items-center justify-between cursor-pointer px-4 py-3',
    'list-none [&::-webkit-details-marker]:hidden',
  ]}>
    <a
      href={`/series/${seriesSlug}`}
      class="text-sm font-semibold text-primary-600 dark:text-primary-400 hover:underline"
      onclick="event.stopPropagation()"
    >
      📚 {seriesName}
      <span class="text-text-muted font-normal">({currentOrder}/{total})</span>
    </a>
    <span class="text-xs text-text-muted transition-transform details-chevron">▼</span>
  </summary>

  <ul class="border-t border-border px-4 py-2 space-y-1">
    {sortedPosts.map((post) => (
      <li class="text-sm py-1">
        {post.order === currentOrder ? (
          <span class:list={[
            'flex items-center gap-2 font-semibold',
            'text-primary-600 dark:text-primary-400',
            'bg-primary-100 dark:bg-primary-900/40 rounded px-2 py-1',
          ]}>
            <span class="text-text-muted">{post.order}.</span>
            {post.title}
          </span>
        ) : (
          <a
            href={post.href}
            class:list={[
              'flex items-center gap-2 rounded px-2 py-1',
              'text-text-muted hover:text-text hover:bg-surface transition-colors',
            ]}
          >
            <span>{post.order}.</span>
            {post.title}
          </a>
        )}
      </li>
    ))}
  </ul>
</details>

<style>
  details[open] .details-chevron {
    transform: rotate(180deg);
  }
</style>
