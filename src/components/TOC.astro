---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
}

const { headings, title = 'ON THIS PAGE' } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="sticky top-24" aria-label="Table of contents">
    <h2 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">
      {title}
    </h2>
    <ul class="space-y-2 text-sm border-l border-border pl-3">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block text-text-muted hover:text-primary-600 dark:hover:text-primary-400 transition-colors leading-snug',
              heading.depth === 3 && 'pl-3',
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
