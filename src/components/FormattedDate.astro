---
interface Props {
  date: Date;
  locale?: string;
  class?: string;
}

const { date, locale = 'ko-KR', class: className } = Astro.props;
---

<time datetime={date.toISOString()} class={className}>
  {date.toLocaleDateString(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })}
</time>
