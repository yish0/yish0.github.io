---
interface Props {
  title: string;
  description: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<section class:list={['py-12 sm:py-16', className]}>
  <h1 class="text-4xl sm:text-5xl font-bold font-heading mb-4">{title}</h1>
  <p class="text-lg text-text-muted max-w-2xl">{description}</p>
  <slot />
</section>
