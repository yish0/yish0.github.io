---
interface Props {
  name: string;
  href?: string;
  size?: 'sm' | 'md';
}

const { name, href, size = 'sm' } = Astro.props;

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
};

const baseClasses = `inline-block rounded-full font-medium transition-colors
  bg-primary-100 text-primary-700
  dark:bg-primary-900 dark:text-primary-300
  hover:bg-primary-200 dark:hover:bg-primary-800
  ${sizeClasses[size]}`;
---

{href ? (
  <a href={href} class={baseClasses}>{name}</a>
) : (
  <span class={baseClasses}>{name}</span>
)}
